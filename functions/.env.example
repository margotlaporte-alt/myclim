# Firebase Functions environment
APP_BASE_URL=https://myclim.app

# Mail transport: graph or smtp
MAIL_TRANSPORT=smtp

# SMTP configuration
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@your-domain.com
SMTP_PASS=your-smtp-password
SMTP_FROM=MyCLIM <no-reply@your-domain.com>

# Optional Microsoft Graph alternative
# MICROSOFT_GRAPH_TENANT_ID=your-tenant-id
# MICROSOFT_GRAPH_CLIENT_ID=your-app-client-id
# MICROSOFT_GRAPH_CLIENT_SECRET=your-app-client-secret
# MICROSOFT_GRAPH_SENDER=no-reply@your-domain.com
# MICROSOFT_GRAPH_FROM=MyCLIM <no-reply@your-domain.com>
