rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Logos partenaires — lecture publique (affichés sur le site public)
    match /sponsors/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Communiqués de presse — lecture publique (téléchargeables sur le site)
    match /press-releases/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Documents internes — lecture réservée aux utilisateurs connectés
    match /documents/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Tout autre fichier — connecté uniquement
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
